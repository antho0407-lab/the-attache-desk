---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Meridians from '../../../components/Meridians.astro';
import { cityBySlug } from '../../../data/cities';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides', (g) => g.data.status === 'published');
  return guides.map((g) => ({
    params: { city: g.data.city, guide: g.data.category },
    props: { guide: g },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const cityInfo = cityBySlug(guide.data.city)!;

// Sibling guides for the same city (for related links)
const related = (await getCollection('guides', (g) => g.data.status === 'published'))
  .filter((g) => g.data.city === guide.data.city && g.id !== guide.id)
  .sort((a, b) => a.data.order - b.data.order);

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
---
<BaseLayout title={guide.data.title} description={guide.data.summary}>
  <section class="doc-head">
    <Meridians />
    <div class="shell doc-head__inner">
      <a class="backlink" href={`/guides-by-city/${guide.data.city}`}>
        <span class="arrow">←</span> {cityInfo.name} guides
      </a>
      <span class="eyebrow eyebrow--on-navy">{guide.data.categoryLabel} · {cityInfo.name}</span>
      <h1>{guide.data.title}</h1>
      <p class="doc-head__sum">{guide.data.summary}</p>

      <div class="cover-strip">
        <div class="cover-strip__cell">
          <div class="cover-strip__k">File ref.</div>
          <div class="cover-strip__v">{guide.data.ref}</div>
        </div>
        <div class="cover-strip__cell">
          <div class="cover-strip__k">Posting</div>
          <div class="cover-strip__v">{cityInfo.name} · {cityInfo.cc}</div>
        </div>
        <div class="cover-strip__cell">
          <div class="cover-strip__k">Category</div>
          <div class="cover-strip__v">{guide.data.categoryLabel}</div>
        </div>
        <div class="cover-strip__cell">
          <div class="cover-strip__k">Last reviewed</div>
          <div class="cover-strip__v">{fmtDate(guide.data.reviewed)}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <article class="prose">
        <Content />
      </article>

      <div class="doc-foot">
        <div class="note">
          <strong>Editorial note</strong>
          Rules on residence, vehicles, schooling and security change, and many
          arrangements depend on your mission, accreditation and personal
          circumstances. Treat this guide as orientation, not authority, and
          confirm specifics with your mission, the host authorities and the
          relevant official sources before acting.
        </div>

        {related.length > 0 && (
          <nav class="related" aria-label="More guides for this city">
            <h2>More for {cityInfo.name}</h2>
            <div class="guide-index">
              {related.map((g) => (
                <a class="guide-index__row" href={`/guides-by-city/${g.data.city}/${g.data.category}`}>
                  <span class="guide-index__cat">{g.data.categoryLabel}</span>
                  <span>
                    <span class="guide-index__title">{g.data.title}</span>
                    <span class="guide-index__sum">{g.data.summary}</span>
                  </span>
                  <span class="guide-index__date">{g.data.ref}</span>
                </a>
              ))}
            </div>
          </nav>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
